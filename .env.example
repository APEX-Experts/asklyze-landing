# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==============================================
# Payload CMS Configuration
# ==============================================

# REQUIRED: Secret key for Payload CMS authentication and encryption
# Generate a strong random string (minimum 32 characters)
# Example: openssl rand -base64 32
PAYLOAD_SECRET=your-strong-random-secret-here

# Database URI for PostgreSQL
DATABASE_URI=postgresql://[username]:[password]@[host]:[port]/[db_name]

# ==============================================
# Next.js Configuration
# ==============================================

# Node environment (development, production, test)
NODE_ENV=development

# Server URL (used for metadata, sitemap, etc.)
# For development: http://localhost:3076
# For production: https://yourdomain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3076

# REQUIRED IN PRODUCTION: Public site URL used by the Payload afterChange hook
# to call the Next.js /api/revalidate endpoint and bust the ISR cache.
# Without this, edits in Payload admin will NOT reflect in the live site.
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Application port (default: 3076)
PORT=3076


# ==============================================
# SendGrid Configuration
# ==============================================

SENDGRID_API_KEY=SG.****
MAIL_FROM=noreply@yourdomain.com

# ==============================================
# Google Ads and Analytics
# ==============================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADS_ID=